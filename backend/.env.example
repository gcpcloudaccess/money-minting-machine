# --- LLM provider (required: set at least one key) ---
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Optional news API (falls back to free RSS if unset) ---
NEWSAPI_KEY=

# --- Data mode ---
# live   = pull real-time/delayed quotes via yfinance, only meaningful during NSE hours (9:15-15:30 IST, Mon-Fri)
# replay = replay cached recent historical intraday bars at accelerated speed, works any time (demo-friendly)
DATA_MODE=replay

# --- Database ---
DATABASE_URL=sqlite:///./investment_committee.db

# --- Trading session parameters ---
STARTING_CAPITAL_INR=10000
LEVERAGE=2
SESSION_HOURS=4
TICK_MINUTES=10
WATCHLIST=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS,LT.NS,SBIN.NS,ITC.NS

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
